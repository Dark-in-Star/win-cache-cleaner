<Window x:Class="WinCacheCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Cache Cleaner"
        Width="720" Height="780"
        MinWidth="720" MinHeight="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Icon="icon.png"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.Resources>

        <!-- ── Gradient brushes ───────────────────────────────────────────── -->
        <LinearGradientBrush x:Key="NeonButtonGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#6366F1" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="NeonButtonHoverGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#818CF8" Offset="0"/>
            <GradientStop Color="#C084FC" Offset="1"/>
        </LinearGradientBrush>

        <!-- ── Checkbox style ─────────────────────────────────────────────── -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder"
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    CornerRadius="4"
                                    BorderThickness="1.5"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    Background="Transparent"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 3,9 L 7,13 L 15,5"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="9,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CheckBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="CheckBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent button (gradient + neon glow) ──────────────────────── -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="32,12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="10"
                                Background="{StaticResource NeonButtonGradient}"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#6366F1" BlurRadius="22" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource NeonButtonHoverGradient}"/>
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A855F7" BlurRadius="35" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary button ──────────────────────────────────────────── -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window control button ──────────────────────────────────────── -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button (red neon hover) ─────────────────────────────── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#EF4444" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Progress bar (neon gradient + glow) ───────────────────────── -->
        <Style x:Key="SlimProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    CornerRadius="4"
                                    Background="{DynamicResource ProgressTrackColor}"
                                    Height="8"/>
                            <Border x:Name="PART_Indicator"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Height="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="0.5"/>
                                        <GradientStop Color="#06B6D4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#6366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Scrollbar (neon gradient thumb) ───────────────────────────── -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border CornerRadius="3" Background="{DynamicResource ProgressTrackColor}" Opacity="0.5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StyledScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       x:Name="PART_VerticalScrollBar"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource ThinScrollBar}"
                                       Margin="3,0,0,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══ Outer neon glow ════════════════════════════════════════════════ -->
    <Border Margin="18" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect Color="#6366F1" BlurRadius="48" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <!-- ══ Gradient ring border (indigo → purple → cyan) ════════════ -->
        <Border CornerRadius="14" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#A855F7" Offset="0.35"/>
                    <GradientStop Color="#06B6D4" Offset="0.65"/>
                    <GradientStop Color="#6366F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- ══ Inner content (1.5px gap reveals ring) ════════════════ -->
            <Border CornerRadius="13" Margin="1.5"
                    Background="{DynamicResource WindowBackground}"
                    ClipToBounds="True"
                    TextOptions.TextFormattingMode="Display"
                    TextOptions.TextRenderingMode="ClearType"
                    RenderOptions.ClearTypeHint="Enabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="62"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="65"/>
                    </Grid.RowDefinitions>

                    <!-- Ambient neon glow blobs (background decoration) -->
                    <Rectangle Grid.RowSpan="11"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Width="380" Height="380" Margin="-100,-100,0,0"
                               IsHitTestVisible="False" Opacity="0.045">
                        <Rectangle.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Grid.RowSpan="11"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Width="380" Height="380" Margin="0,0,-100,-100"
                               IsHitTestVisible="False" Opacity="0.04">
                        <Rectangle.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Grid.RowSpan="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Width="300" Height="200"
                               IsHitTestVisible="False" Opacity="0.02">
                        <Rectangle.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#06B6D4" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ── Title bar ───────────────────────────────────────── -->
                    <Border Grid.Row="0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Border.Background>
                            <DynamicResource ResourceKey="HeaderGradient"/>
                        </Border.Background>
                        <Grid Margin="14,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="icon.png" Width="26" Height="26"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Windows Cache Cleaner"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#818CF8" Offset="0"/>
                                            <GradientStop Color="#C084FC" Offset="0.5"/>
                                            <GradientStop Color="#22D3EE" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ThemeBtn" Content="🌙"
                                        ToolTip="Toggle light / dark"
                                        Style="{StaticResource WinCtrlButton}"
                                        Click="ThemeBtn_Click" Margin="0,0,2,0"/>
                                <Button Content="—" ToolTip="Minimize"
                                        Style="{StaticResource WinCtrlButton}"
                                        Click="MinimizeBtn_Click" Margin="0,0,2,0"/>
                                <Button Content="✕" ToolTip="Close"
                                        Style="{StaticResource CloseButton}"
                                        Click="CloseBtn_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Neon rainbow separator -->
                    <Border Grid.Row="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent"  Offset="0"/>
                                <GradientStop Color="#6366F1"      Offset="0.2"/>
                                <GradientStop Color="#A855F7"      Offset="0.5"/>
                                <GradientStop Color="#06B6D4"      Offset="0.8"/>
                                <GradientStop Color="Transparent"  Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- ── Controls bar ─────────────────────────────────────── -->
                    <Border Grid.Row="2" Background="{DynamicResource WindowBackground}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <TextBlock Text="SELECT TASKS"
                                       FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#A855F7" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <Button Content="Select All"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SelectAll_Click"/>
                            <Button Content="Deselect All"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Click="DeselectAll_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Subtle separator -->
                    <Border Grid.Row="3" Background="{DynamicResource SeparatorColor}"/>

                    <!-- ── Task grid ────────────────────────────────────────── -->
                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="330"
                                  Style="{StaticResource StyledScrollViewer}">
                    <ItemsControl ItemsSource="{Binding Tasks}"
                                  Margin="12,10,12,4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder"
                                        Margin="4,3" Padding="12,10"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        Background="{DynamicResource CardGradient}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="6" ShadowDepth="0" Opacity="0.07"/>
                                    </Border.Effect>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource ModernCheckBox}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="12.5"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#6366F1"/>
                                        <Setter TargetName="CardBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    </ScrollViewer>

                    <!-- ── Progress section ─────────────────────────────────── -->
                    <Border Grid.Row="6"
                            Margin="16,0" Padding="16,13"
                            CornerRadius="10"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                        <Border.Background>
                            <DynamicResource ResourceKey="ProgressCardGradient"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding ProgressText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <ProgressBar Grid.Row="2"
                                         Minimum="0" Maximum="100"
                                         Value="{Binding ProgressPercent}"
                                         Style="{StaticResource SlimProgressBar}"/>
                        </Grid>
                    </Border>

                    <!-- ── Log panel ────────────────────────────────────────── -->
                    <Border Grid.Row="8"
                            Margin="16,0" CornerRadius="10"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                            Background="{DynamicResource LogGradient}"
                            ClipToBounds="True">
                        <ScrollViewer x:Name="LogScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource StyledScrollViewer}">
                            <ItemsControl ItemsSource="{Binding LogEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Icon}"
                                                           Foreground="{Binding IconColor}"
                                                           FontSize="13" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TaskName}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text=" — " FontSize="12"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding Message}" FontSize="12"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Neon rainbow separator -->
                    <Border Grid.Row="9">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent"  Offset="0"/>
                                <GradientStop Color="#6366F1"      Offset="0.2"/>
                                <GradientStop Color="#A855F7"      Offset="0.5"/>
                                <GradientStop Color="#06B6D4"      Offset="0.8"/>
                                <GradientStop Color="Transparent"  Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- ── Footer ───────────────────────────────────────────── -->
                    <Border Grid.Row="10" Background="{DynamicResource HeaderGradient}">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding TotalFreedText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#818CF8" Offset="0"/>
                                        <GradientStop Color="#22D3EE" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <Button Grid.Column="1"
                                    x:Name="RunBtn"
                                    Content="🗑  RUN CLEANUP"
                                    IsEnabled="{Binding CanRun}"
                                    Style="{StaticResource AccentButton}"
                                    Click="RunBtn_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Border>
    </Border>
</Window>
