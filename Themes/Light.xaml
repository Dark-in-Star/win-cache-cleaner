<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Background layers ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBackground"  Color="#F0F2F8"/>
    <SolidColorBrush x:Key="HeaderBackground"  Color="#E2E6F0"/>
    <SolidColorBrush x:Key="CardBackground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LogBackground"     Color="#F8F9FC"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary"       Color="#383A42"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#717277"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentColor"       Color="#0366D6"/>
    <SolidColorBrush x:Key="AccentHoverColor"  Color="#0453B4"/>

    <!-- ── Status ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SuccessColor"      Color="#22863A"/>
    <SolidColorBrush x:Key="WarningColor"      Color="#E36209"/>
    <SolidColorBrush x:Key="ErrorColor"        Color="#D73A49"/>

    <!-- ── UI elements ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderColor"       Color="#D0D4E0"/>
    <SolidColorBrush x:Key="ButtonForeground"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ProgressTrackColor" Color="#D0D4E0"/>
    <SolidColorBrush x:Key="SeparatorColor"    Color="#D0D4E0"/>

</ResourceDictionary>
