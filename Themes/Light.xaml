<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Solid backgrounds ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBackground"    Color="#F0F2F8"/>
    <SolidColorBrush x:Key="HeaderBackground"    Color="#E2E6F0"/>
    <SolidColorBrush x:Key="CardBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LogBackground"       Color="#F8F9FC"/>
    <SolidColorBrush x:Key="HoverBackground"     Color="#E4E8F4"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary"         Color="#1E2035"/>
    <SolidColorBrush x:Key="TextSecondary"       Color="#717277"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentColor"         Color="#6366F1"/>
    <SolidColorBrush x:Key="AccentHoverColor"    Color="#4F52D9"/>

    <!-- ── Status ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="SuccessColor"        Color="#059669"/>
    <SolidColorBrush x:Key="WarningColor"        Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorColor"          Color="#DC2626"/>

    <!-- ── UI structure ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderColor"         Color="#D0D4E8"/>
    <SolidColorBrush x:Key="ButtonForeground"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ProgressTrackColor"  Color="#D8DBE8"/>
    <SolidColorBrush x:Key="SeparatorColor"      Color="#D8DBE8"/>

    <!-- ── Gradient brushes ───────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#DDE1EE" Offset="0"/>
        <GradientStop Color="#E8EBF6" Offset="0.5"/>
        <GradientStop Color="#DDE1EE" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F6F7FC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ProgressCardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#ECEEF8" Offset="0"/>
        <GradientStop Color="#E4E7F4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LogGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F8F9FC" Offset="0"/>
        <GradientStop Color="#F3F5FA" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
